generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model EmotionVote {
  id        Int      @id @default(autoincrement())
  emotion   String
  category  String
  visitorId String
  createdAt DateTime @default(now())

  @@index([visitorId, createdAt])
  @@index([createdAt])
  @@index([emotion])
}
